<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HealthCenter.Desktop.Features.Nurse.ViewModels"
             xmlns:converters="using:HealthCenter.Desktop.Infrastructure.Converters"
             x:Class="HealthCenter.Desktop.Features.Nurse.Views.NursePanelView"
             x:DataType="vm:NursePanelViewModel"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <converters:TicketStatusConverter x:Key="TicketStatusConverter"/>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*" Background="#F8FAFC">

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="20,14" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="لوحة التمريض" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
                    <TextBlock Text="استقبال المرضى وتسجيل العلامات الحيوية" FontSize="13" Foreground="#64748B"/>
                </StackPanel>
                <Button Grid.Column="1" Content="تحديث" Command="{Binding RefreshQueueCommand}"
                        Padding="14,8" CornerRadius="6"
                        Background="#2563EB" Foreground="White"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" ColumnDefinitions="340,*" Margin="16">

            <!-- Left: Patient Queue -->
            <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="16" Margin="0,0,12,0"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="قائمة الانتظار اليوم" FontWeight="SemiBold" FontSize="15"
                               Foreground="#1E293B" Margin="0,0,0,12"/>
                    <ScrollViewer Grid.Row="1" IsVisible="{Binding !HasNoPatients}">
                        <ListBox ItemsSource="{Binding WaitingQueue}"
                                 SelectedItem="{Binding SelectedTicket}"
                                 Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,10" CornerRadius="6" Background="#F8FAFC"
                                            Margin="0,0,0,6" BorderBrush="#E2E8F0" BorderThickness="1">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <Border Grid.Column="0" Background="#DBEAFE" CornerRadius="6"
                                                    Padding="10,6" Margin="0,0,10,0">
                                                <TextBlock Text="{Binding TicketNumber}"
                                                           FontWeight="Bold" FontSize="16" Foreground="#1D4ED8"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Patient.FullName}" FontWeight="Medium" Foreground="#1E293B"/>
                                                <TextBlock Text="{Binding Status, Converter={StaticResource TicketStatusConverter}}" FontSize="12" Foreground="#94A3B8"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                    <StackPanel Grid.Row="1" IsVisible="{Binding HasNoPatients}"
                                VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                        <TextBlock Text="🏥" FontSize="40" HorizontalAlignment="Center"/>
                        <TextBlock Text="لا يوجد مرضى في الانتظار حالياً" FontSize="15"
                                   Foreground="#94A3B8" HorizontalAlignment="Center"/>
                        <TextBlock Text="سيظهر المرضى عند تسجيلهم من الاستقبال" FontSize="12"
                                   Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Right: Vitals Form -->
            <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="24"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid RowDefinitions="Auto,Auto,*,Auto">

                    <TextBlock Grid.Row="0" Text="تسجيل العلامات الحيوية" FontSize="17" FontWeight="SemiBold"
                               Foreground="#1E293B" Margin="0,0,0,4"/>
                    <TextBlock Grid.Row="1"
                               Text="{Binding SelectedTicket.Patient.FullName, FallbackValue='لم يتم تحديد مريض بعد'}"
                               FontSize="14" Foreground="#64748B" Margin="0,0,0,20"/>

                    <StackPanel Grid.Row="2" Spacing="16">
                        <Grid ColumnDefinitions="*,20,*">
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="ضغط الدم (mmHg)" Foreground="#374151" FontWeight="Medium"/>
                                <TextBox Text="{Binding BloodPressure}" Watermark="120/80"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="6">
                                <TextBlock Text="الحرارة (درجة مئوية)" Foreground="#374151" FontWeight="Medium"/>
                                <TextBox Text="{Binding Temperature}" Watermark="37.0"/>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,20,*">
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="نبضات القلب (في الدقيقة)" Foreground="#374151" FontWeight="Medium"/>
                                <TextBox Text="{Binding HeartRate}" Watermark="72"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="6">
                                <TextBlock Text="الوزن (كيلوغرام)" Foreground="#374151" FontWeight="Medium"/>
                                <TextBox Text="{Binding Weight}" Watermark="70"/>
                            </StackPanel>
                        </Grid>

                        <!-- Status message: success -->
                        <Border IsVisible="{Binding IsError, Converter={x:Static BoolConverters.Not}}"
                                CornerRadius="6" Padding="12,8" Margin="0,0,0,8"
                                Background="#F0FDF4">
                            <TextBlock Text="{Binding StatusMessage}"
                                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                       Foreground="#15803D" TextWrapping="Wrap" FontWeight="Medium"/>
                        </Border>
                        <!-- Status message: error -->
                        <Border CornerRadius="6" Padding="12,8" Margin="0,0,0,8"
                                Background="#FEF2F2"
                                IsVisible="{Binding IsError}">
                            <TextBlock Text="{Binding StatusMessage}"
                                       Foreground="#DC2626" TextWrapping="Wrap" FontWeight="Medium"/>
                        </Border>
                    </StackPanel>

                    <Button Grid.Row="3" Content="حفظ وإرسال للطبيب"
                            Command="{Binding SaveVitalsCommand}"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Padding="0,12" FontSize="15" FontWeight="SemiBold"
                            Background="#2563EB" Foreground="White" CornerRadius="8"
                            Margin="0,20,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
