<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HealthCenter.Desktop.Features.Reception.ViewModels"
             xmlns:entities="using:HealthCenter.Desktop.Database.Entities"
             x:Class="HealthCenter.Desktop.Features.Reception.Views.ReceptionView"
             x:DataType="vm:ReceptionViewModel"
             FlowDirection="RightToLeft">

    <UserControl.Styles>
        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="CaretBrush" Value="#2563EB"/>
        </Style>
        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#93C5FD"/>
        </Style>
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" Background="#F8FAFC">

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="20,14" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="الاستقبال وتسجيل المرضى" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
                    <TextBlock Text="{Binding TodayCount, StringFormat='تذاكر اليوم: {0} | في الانتظار: '}"
                               FontSize="13" Foreground="#64748B"/>
                </StackPanel>
                <Button Grid.Column="1" Content="تحديث" Command="{Binding RefreshQueueCommand}"
                        Padding="14,8" CornerRadius="6" Background="#2563EB" Foreground="White"/>
            </Grid>
        </Border>

        <!-- Main area: 3 columns -->
        <Grid Grid.Row="1" ColumnDefinitions="380,*,320" Margin="12">

            <!-- ====== COL 1: Registration Form ====== -->
            <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="20"
                    Margin="0,0,10,0" BorderBrush="#E2E8F0" BorderThickness="1">
                <ScrollViewer>
                    <StackPanel Spacing="12">

                        <TextBlock Text="تسجيل مريض جديد"
                                   IsVisible="{Binding IsEditMode, Converter={x:Static BoolConverters.Not}}"
                                   FontSize="17" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="تعديل بيانات المريض"
                                   IsVisible="{Binding IsEditMode}"
                                   FontSize="17" FontWeight="Bold" Foreground="#2563EB"/>

                        <!-- Status message: success
                             Outer Panel: hide entirely when StatusMessage is empty.
                             Inner Border: hide when IsError is true (shows only on success). -->
                        <Panel IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <Border IsVisible="{Binding IsError, Converter={x:Static BoolConverters.Not}}"
                                    CornerRadius="6" Padding="12,8"
                                    Background="#F0FDF4">
                                <TextBlock Text="{Binding StatusMessage}"
                                           Foreground="#15803D" TextWrapping="Wrap"/>
                            </Border>
                        </Panel>
                        <!-- Status message: error -->
                        <Border IsVisible="{Binding IsError}"
                                CornerRadius="6" Padding="12,8"
                                Background="#FEF2F2">
                            <TextBlock Text="{Binding StatusMessage}"
                                       Foreground="#DC2626" TextWrapping="Wrap"/>
                        </Border>

                        <!-- Full Name -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="الاسم الكامل *" Foreground="#374151" FontWeight="Medium"/>
                            <TextBox Text="{Binding PatientName}" Watermark="أحمد محمد العمري"/>
                        </StackPanel>

                        <!-- National ID -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="الرقم الوطني / الإقامة" Foreground="#374151" FontWeight="Medium"/>
                            <TextBox Text="{Binding NationalId}" Watermark="1090123456" MaxLength="12"/>
                        </StackPanel>

                        <!-- Phone -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="رقم الهاتف *" Foreground="#374151" FontWeight="Medium"/>
                            <TextBox Text="{Binding PhoneNumber}" Watermark="0501234567" MaxLength="15"/>
                        </StackPanel>

                        <!-- Emergency Contact -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="هاتف الطوارئ" Foreground="#374151" FontWeight="Medium"/>
                            <TextBox Text="{Binding EmergencyContact}" Watermark="05xxxxxxxx" MaxLength="15"/>
                        </StackPanel>

                        <!-- Gender + Blood Type row -->
                        <Grid ColumnDefinitions="*,10,*">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="الجنس" Foreground="#374151" FontWeight="Medium"/>
                                <ComboBox ItemsSource="{Binding GenderOptions}"
                                          SelectedItem="{Binding SelectedGender}"
                                          HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="فصيلة الدم" Foreground="#374151" FontWeight="Medium"/>
                                <ComboBox ItemsSource="{Binding BloodTypes}"
                                          SelectedItem="{Binding SelectedBloodType}"
                                          HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Grid>

                        <!-- Date of Birth -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="تاريخ الميلاد" Foreground="#374151" FontWeight="Medium"/>
                            <CalendarDatePicker SelectedDate="{Binding SelectedBirthDate}"
                                                HorizontalAlignment="Stretch" Height="40"
                                                IsTodayHighlighted="True"/>
                        </StackPanel>

                        <!-- Address -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="العنوان" Foreground="#374151" FontWeight="Medium"/>
                            <TextBox Text="{Binding Address}" Watermark="المدينة، الحي"/>
                        </StackPanel>

                        <!-- Allergies -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="الحساسية الدوائية" Foreground="#374151" FontWeight="Medium"/>
                            <TextBox Text="{Binding Allergies}" Watermark="بنسلين، إيبوبروفين ..."/>
                        </StackPanel>

                        <!-- Chronic Conditions -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="الأمراض المزمنة" Foreground="#374151" FontWeight="Medium"/>
                            <TextBox Text="{Binding ChronicConditions}" Watermark="السكري، ضغط الدم ..."/>
                        </StackPanel>

                        <!-- Insurance -->
                        <Grid ColumnDefinitions="*,10,*">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="شركة التأمين" Foreground="#374151" FontWeight="Medium"/>
                                <TextBox Text="{Binding InsuranceProvider}" Watermark="بوبا، ميدنت ..."/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="رقم التأمين" Foreground="#374151" FontWeight="Medium"/>
                                <TextBox Text="{Binding InsuranceNumber}" Watermark="INS-0000"/>
                            </StackPanel>
                        </Grid>

                        <!-- Save / Cancel -->
                        <Button Content="حفظ المريض"
                                IsVisible="{Binding IsEditMode, Converter={x:Static BoolConverters.Not}}"
                                Command="{Binding SavePatientCommand}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Padding="0,12" FontSize="15" FontWeight="SemiBold"
                                Background="#2563EB" Foreground="White" CornerRadius="8"/>
                        <Button Content="تحديث بيانات المريض"
                                IsVisible="{Binding IsEditMode}"
                                Command="{Binding SavePatientCommand}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Padding="0,12" FontSize="15" FontWeight="SemiBold"
                                Background="#16A34A" Foreground="White" CornerRadius="8"/>

                        <Button Content="الغاء التعديل"
                                Command="{Binding CancelEditCommand}"
                                IsVisible="{Binding IsEditMode}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Padding="0,10" Background="#FEE2E2" Foreground="#DC2626" CornerRadius="8"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ====== COL 2: Search & Patient List ====== -->
            <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="16"
                    Margin="0,0,10,0" BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid RowDefinitions="Auto,*">

                    <!-- Search bar -->
                    <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,12">
                        <TextBlock Text="بحث عن مريض" FontSize="17" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBox Text="{Binding SearchQuery}"
                                 Watermark="ابحث بالاسم أو الرقم الوطني أو الهاتف..."/>
                    </StackPanel>

                    <!-- Results -->
                    <ScrollViewer Grid.Row="1">
                        <ItemsControl ItemsSource="{Binding SearchResults}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="entities:Patient">
                                    <Border Background="#F8FAFC" CornerRadius="8" Padding="14,10"
                                            Margin="0,0,0,8" BorderBrush="#E2E8F0" BorderThickness="1">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Spacing="3">
                                                <TextBlock Text="{Binding FullName}" FontWeight="SemiBold"
                                                           FontSize="15" Foreground="#1E293B"/>
                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                    <TextBlock Text="{Binding NationalId, FallbackValue='—'}"
                                                               FontSize="12" Foreground="#64748B"/>
                                                    <TextBlock Text="{Binding PhoneNumber}"
                                                               FontSize="12" Foreground="#64748B"/>
                                                    <TextBlock Text="{Binding BloodType, FallbackValue=''}"
                                                               FontSize="12" Foreground="#EF4444" FontWeight="Medium"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding ChronicConditions, StringFormat='أمراض: {0}', FallbackValue=''}"
                                                               FontSize="11" Foreground="#94A3B8"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Action buttons -->
                                            <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                                <Button Content="اصدر تذكرة"
                                                        Command="{Binding $parent[ItemsControl].((vm:ReceptionViewModel)DataContext).IssueTicketCommand}"
                                                        CommandParameter="{Binding}"
                                                        Background="#2563EB" Foreground="White"
                                                        CornerRadius="6" Padding="10,6" FontSize="12"/>
                                                <Button Content="تعديل"
                                                        Command="{Binding $parent[ItemsControl].((vm:ReceptionViewModel)DataContext).EditPatientCommand}"
                                                        CommandParameter="{Binding}"
                                                        Background="#F1F5F9" Foreground="#475569"
                                                        CornerRadius="6" Padding="10,6" FontSize="12"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ====== COL 3: Today's Queue ====== -->
            <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="16"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid RowDefinitions="Auto,*">
                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="طابور اليوم" FontSize="17" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="{Binding WaitingCount, StringFormat='في الانتظار: {0}'}"
                                   FontSize="13" Foreground="#64748B"/>
                    </StackPanel>
                    <ScrollViewer Grid.Row="1">
                        <ItemsControl ItemsSource="{Binding TodayQueue}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8FAFC" CornerRadius="8" Padding="12,8"
                                            Margin="0,0,0,6" BorderBrush="#E2E8F0" BorderThickness="1">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <Border Grid.Column="0" Background="#DBEAFE" CornerRadius="6"
                                                    Padding="10,6" Margin="0,0,10,0">
                                                <TextBlock Text="{Binding TicketNumber}"
                                                           FontSize="18" FontWeight="Bold" Foreground="#1D4ED8"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Patient.FullName}"
                                                           FontWeight="Medium" Foreground="#1E293B"/>
                                                <TextBlock Text="{Binding Status}"
                                                           FontSize="11" Foreground="#94A3B8"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>