<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HealthCenter.Desktop.Features.Reception.ViewModels"
        x:Class="HealthCenter.Desktop.Features.Reception.Views.TicketDialog"
        x:DataType="vm:ReceptionViewModel"
        Title="تذكرة مريض"
        Width="400" Height="650"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="BorderOnly"
        TransparencyLevelHint="AcrylicBlur"
        Background="Transparent">

    <Border Background="White" CornerRadius="8" Padding="20" BoxShadow="0 10 30 0 #40000000" BorderBrush="#E2E8F0" BorderThickness="1">
        <Grid RowDefinitions="*,Auto">
            
            <StackPanel Grid.Row="0">
                <StackPanel HorizontalAlignment="Center" Spacing="5" Margin="0,0,0,10">
                    <Border BorderBrush="Black" BorderThickness="2" CornerRadius="50" Width="50" Height="50" Margin="0,0,0,5">
                        <TextBlock Text="🏥" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="المركز الصحي" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center" Foreground="Black"/>
                    <TextBlock Text="Health Center" FontSize="12" Foreground="Black" HorizontalAlignment="Center"/>
                </StackPanel>
                
                <Rectangle Height="1" Stroke="Black" StrokeThickness="2" HorizontalAlignment="Stretch" Margin="0,5"/>

                <TextBlock Text="رقم التذكرة" HorizontalAlignment="Center" Foreground="Black" FontSize="14" Margin="0,10,0,0"/>
                <TextBlock x:Name="TicketNumberTxt" Text="---" HorizontalAlignment="Center" FontWeight="Black" FontSize="60" Foreground="Black" Margin="0,-5,0,10"/>

                <Rectangle Height="1" Stroke="Black" StrokeThickness="1" StrokeDashArray="4,2" HorizontalAlignment="Stretch" Margin="0,10"/>

                <StackPanel Spacing="10" Margin="5">
                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Grid.Column="0" Text="الاسم:" FontWeight="Bold" Foreground="Black"/>
                        <TextBlock Grid.Column="1" x:Name="PatientNameTxt" Text="---" HorizontalAlignment="Left" Foreground="Black" TextWrapping="Wrap" Margin="10,0,0,0"/>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Grid.Column="0" Text="التاريخ:" FontWeight="Bold" Foreground="Black"/>
                        <TextBlock Grid.Column="1" x:Name="DateTxt" Text="---" HorizontalAlignment="Left" Foreground="Black" Margin="10,0,0,0"/>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Grid.Column="0" Text="الوقت:" FontWeight="Bold" Foreground="Black"/>
                        <TextBlock Grid.Column="1" x:Name="TimeTxt" Text="---" HorizontalAlignment="Left" Foreground="Black" Margin="10,0,0,0"/>
                    </Grid>
                </StackPanel>

                <Rectangle Height="1" Stroke="Black" StrokeThickness="1" HorizontalAlignment="Stretch" Margin="0,15,0,10"/>

                <Border Background="Black" Padding="10" CornerRadius="4">
                    <TextBlock x:Name="WaitingCountTxt" Text="أمامك: --" Foreground="White" HorizontalAlignment="Center" FontWeight="Bold" FontSize="16"/>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,20,0,0">
                
                <Border Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                    <StackPanel Spacing="10">
                        <TextBlock Text="يمكنك إغلاق هذه النافذة بعد الاطلاع على التذكرة." 
                                   FontSize="12" Foreground="#64748B" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Button Content="إغلاق" Click="Close_Click"
                        Background="#2563EB" Foreground="White"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        CornerRadius="6" Padding="10,12" FontWeight="Bold"/>
            </StackPanel>
        </Grid>
    </Border>

</Window>