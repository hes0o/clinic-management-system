<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:HealthCenter.Desktop.Features.Doctor.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="HealthCenter.Desktop.Features.Doctor.Views.DoctorPanelView"
             x:DataType="vm:DoctorPanelViewModel"
             FlowDirection="RightToLeft">

    <Design.DataContext>
        <vm:DoctorPanelViewModel/>
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,10"/>
        </Style>
        <Style Selector="Button.primary:pointerover">
            <Setter Property="Background" Value="#1D4ED8"/>
        </Style>
        <Style Selector="Button.primary:pressed">
            <Setter Property="Background" Value="#1E40AF"/>
            <Setter Property="RenderTransform" Value="scale(0.98)"/>
        </Style>

        <Style Selector="Button.success">
            <Setter Property="Background" Value="#16A34A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,10"/>
        </Style>
        <Style Selector="Button.success:pointerover">
            <Setter Property="Background" Value="#15803D"/>
        </Style>
        <Style Selector="Button.success:pressed">
            <Setter Property="Background" Value="#166534"/>
            <Setter Property="RenderTransform" Value="scale(0.98)"/>
        </Style>

        <Style Selector="Button.warning">
            <Setter Property="Background" Value="#F59E0B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,10"/>
        </Style>
        <Style Selector="Button.warning:pointerover">
            <Setter Property="Background" Value="#D97706"/>
        </Style>
        <Style Selector="Button.warning:pressed">
            <Setter Property="Background" Value="#B45309"/>
            <Setter Property="RenderTransform" Value="scale(0.98)"/>
        </Style>

        <Style Selector="Button.danger">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,10"/>
        </Style>
        <Style Selector="Button.danger:pointerover">
            <Setter Property="Background" Value="#B91C1C"/>
        </Style>
        <Style Selector="Button.danger:pressed">
            <Setter Property="Background" Value="#991B1B"/>
            <Setter Property="RenderTransform" Value="scale(0.98)"/>
        </Style>

        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="CaretBrush" Value="#2563EB"/>
            <Setter Property="SelectionBrush" Value="#BFDBFE"/>
        </Style>
        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#93C5FD"/>
            <Setter Property="Background" Value="#F0F9FF"/>
        </Style>
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style Selector="TextBox /template/ TextBlock#PART_Watermark">
            <Setter Property="Foreground" Value="#9CA3AF"/>
        </Style>
    </UserControl.Styles>

    <Grid Background="#F3F4F6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Waiting List -->
        <Border Grid.Column="0" Background="White" Padding="20">
            <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,Auto">
                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="لوحة الطبيب" 
                               FontSize="24" 
                               FontWeight="Bold"
                               Foreground="#1E293B"/>
                    <TextBlock Text="{Binding WaitingCount, StringFormat='في الانتظار: {0}'}" 
                               FontSize="14" 
                               Foreground="#64748B"/>
                </StackPanel>

                <!-- Task 3: Statistics Dashboard -->
                <Border Grid.Row="1" Background="#F8FAFC" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="احصائيات اليوم" FontWeight="SemiBold" FontSize="14" Foreground="#1E293B"/>
                        
                        <!-- Today Patients -->
                        <Border Background="#DBEAFE" CornerRadius="8" Padding="12,8">
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Grid.Column="0" Text="اليوم" FontSize="18" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding TodayPatients}" FontSize="20" FontWeight="Bold" Foreground="#1E40AF"/>
                                    <TextBlock Text="مرضى اليوم" FontSize="12" Foreground="#64748B"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Week Patients -->
                        <Border Background="#D1FAE5" CornerRadius="8" Padding="12,8">
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Grid.Column="0" Text="الاسبوع" FontSize="18" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding WeekPatients}" FontSize="20" FontWeight="Bold" Foreground="#065F46"/>
                                    <TextBlock Text="مرضى الأسبوع" FontSize="12" Foreground="#64748B"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Month Patients -->
                        <Border Background="#FEF3C7" CornerRadius="8" Padding="12,8">
                            <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Grid.Column="0" Text="الشهر" FontSize="18" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding MonthPatients}" FontSize="20" FontWeight="Bold" Foreground="#92400E"/>
                                    <TextBlock Text="مرضى الشهر" FontSize="12" Foreground="#64748B"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Call Next Button - its own row, below stats -->
                <Button Grid.Row="2" 
                        Classes="primary"
                        Command="{Binding CallNextCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Margin="0,0,0,12"
                        FontSize="16"
                        Padding="16,12">
                    <TextBlock Text="نداء المريض التالي" FontWeight="SemiBold"/>
                </Button>

                <!-- Waiting Patients List -->
                <Border Grid.Row="3" Background="#F8FAFC" CornerRadius="12" Padding="12">
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding WaitingPatients}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" 
                                            CornerRadius="8" 
                                            Padding="12"
                                            Margin="0,0,0,8"
                                            BoxShadow="0 1 2 0 #0a000000">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <!-- Ticket Number -->
                                            <Border Grid.Column="0" 
                                                    Background="#E0F2FE" 
                                                    CornerRadius="8" 
                                                    Padding="12,8"
                                                    Margin="0,0,12,0">
                                                <TextBlock Text="{Binding TicketNumber}" 
                                                           FontSize="20" 
                                                           FontWeight="Bold"
                                                           Foreground="#0369A1"/>
                                            </Border>

                                            <!-- Patient Info -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Patient.FullName}" 
                                                           FontWeight="Medium"/>
                                                <TextBlock Text="{Binding Status, Converter={StaticResource TicketStatusConverter}}" 
                                                           FontSize="12"
                                                           Foreground="#94A3B8"/>
                                            </StackPanel>

                                            <!-- Call Button -->
                                            <Button Grid.Column="2"
                                                    Command="{Binding $parent[ItemsControl].((vm:DoctorPanelViewModel)DataContext).CallSpecificCommand}"
                                                    CommandParameter="{Binding}"
                                                    Background="#10B981"
                                                    Foreground="White"
                                                    CornerRadius="6"
                                                    Padding="10,6"
                                                    Content="نداء"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Absent recall list (compact) -->
                <Expander Grid.Row="4"
                          Header="قائمة الغائبين (لإعادة النداء)"
                          Margin="0,12,0,0"
                          CornerRadius="10"
                          Background="#F8FAFC">
                    <Border Background="White" CornerRadius="8" Padding="10" Margin="0,8,0,0">
                        <ScrollViewer MaxHeight="180">
                            <ItemsControl ItemsSource="{Binding AbsentRecallPatients}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F8FAFC" CornerRadius="8" Padding="10" Margin="0,0,0,8"
                                                BorderBrush="#E2E8F0" BorderThickness="1">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <StackPanel Grid.Column="0" Spacing="2">
                                                    <TextBlock Text="{Binding Patient.FullName}" FontWeight="Medium"/>
                                                    <TextBlock Text="{Binding TicketNumber, StringFormat='رقم التذكرة: {0}'}"
                                                               FontSize="12" Foreground="#64748B"/>
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Command="{Binding $parent[ItemsControl].((vm:DoctorPanelViewModel)DataContext).RecallAbsentCommand}"
                                                        CommandParameter="{Binding}"
                                                        Background="#2563EB" Foreground="White"
                                                        CornerRadius="6" Padding="10,6"
                                                        Content="إعادة نداء"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Expander>

                <!-- Completed today stats -->
                <Border Grid.Row="5" Background="#F0FDF4" CornerRadius="8" Padding="12" Margin="0,12,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="24">
                        <TextBlock Text="تم اليوم:" Foreground="#166534"/>
                        <TextBlock Text="{Binding CompletedToday}" 
                                   FontWeight="Bold" 
                                   FontSize="18"
                                   Foreground="#166534"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Right: Current Patient & Diagnosis -->
        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Current Patient Card -->
            <Border Grid.Row="0" 
                    Background="White" 
                    CornerRadius="16" 
                    Padding="24"
                    Margin="0,0,0,20">
                <Grid RowDefinitions="Auto,Auto">
                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="المريض الحالي" 
                                   FontSize="16" 
                                   Foreground="#64748B"/>
                        <StackPanel Orientation="Horizontal" Spacing="20" Margin="0,8,0,0">
                            <!-- Ticket Number -->
                            <Border Background="#22D3EE" 
                                    CornerRadius="12" 
                                    Padding="24,16">
                                <TextBlock Text="{Binding CurrentPatient.TicketNumber, FallbackValue='-'}" 
                                           FontSize="48" 
                                           FontWeight="ExtraBold"
                                           Foreground="#0F172A"/>
                            </Border>
                            <!-- Patient Name -->
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding CurrentPatient.Patient.FullName, FallbackValue='لا يوجد مريض'}" 
                                           FontSize="32" 
                                           FontWeight="Bold"
                                           Foreground="#1E293B"/>
                                <TextBlock Text="{Binding CurrentPatient.Patient.PhoneNumber}" 
                                           FontSize="16" 
                                           Foreground="#64748B"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Status Actions -->
                    <StackPanel Grid.Row="1" 
                                Orientation="Horizontal" 
                                Spacing="12"
                                IsVisible="{Binding IsAttendanceActionsVisible}">
                        <Button Classes="success" Command="{Binding MarkPresentCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="حضر"/>
                            </StackPanel>
                        </Button>
                        <Button Classes="warning" Command="{Binding MarkAbsentCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="غائب"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Diagnosis Form -->
            <Border Grid.Row="1" 
                    Background="White" 
                    CornerRadius="16" 
                    Padding="24"
                    IsVisible="{Binding CurrentPatient, Converter={x:Static ObjectConverters.IsNotNull}}">
                <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">
                    <TextBlock Grid.Row="0" 
                               Text="التشخيص والعلاج" 
                               FontSize="20" 
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"/>

                    <!-- Status Banner (Success/Error) -->
                    <!-- Success Banner -->
                    <Border Grid.Row="1" 
                            IsVisible="{Binding IsSuccessMessage}"
                            CornerRadius="8" 
                            Padding="14,10" 
                            Margin="0,0,0,12"
                            Background="#F0FDF4">
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#15803D"
                                   TextWrapping="Wrap" 
                                   FontWeight="Medium"/>
                    </Border>
                    
                    <!-- Error Banner -->
                    <Border Grid.Row="1"
                            IsVisible="{Binding IsError}"
                            CornerRadius="8" 
                            Padding="14,10" 
                            Margin="0,0,0,12"
                            Background="#FEF2F2">
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#DC2626"
                                   TextWrapping="Wrap" 
                                   FontWeight="Medium"/>
                    </Border>

                    <!-- Diagnosis -->
                    <ScrollViewer Grid.Row="2">
                        <StackPanel Spacing="16">
                            <!-- Task 2: Common Diagnosis Dropdown -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="التشخيص السريع" FontWeight="Medium" Foreground="#374151"/>
                                <ComboBox ItemsSource="{Binding CommonDiagnoses}"
                                          SelectedItem="{Binding SelectedDiagnosis}"
                                          PlaceholderText="اختر تشخيص شائع..."
                                          HorizontalAlignment="Stretch"
                                          CornerRadius="8"/>
                            </StackPanel>

                            <!-- Manual Diagnosis Entry -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="التشخيص التفصيلي (حد أقصى 1000 حرف)" FontWeight="Medium" Foreground="#374151"/>
                                <TextBox Text="{Binding Diagnosis}"
                                         MaxLength="1000"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Height="100"
                                         Watermark="أدخل التشخيص التفصيلي (حتى 1000 حرف)..."/>
                            </StackPanel>

                            <!-- Task 2: Vital Signs Section -->
                            <Border Background="#F8FAFC" CornerRadius="12" Padding="16">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="العلامات الحيوية" FontWeight="SemiBold" FontSize="16" Foreground="#1E293B"/>
                                    
                                    <Grid ColumnDefinitions="*,12,*" RowDefinitions="Auto,12,Auto">
                                        <!-- Blood Pressure -->
                                        <StackPanel Grid.Column="0" Grid.Row="0" Spacing="6">
                                            <TextBlock Text="ضغط الدم (mmHg)" FontSize="13" Foreground="#64748B"/>
                                            <TextBox Text="{Binding BloodPressure}" MaxLength="7" Watermark="مثال: 120/80"/>
                                        </StackPanel>

                                        <!-- Temperature -->
                                        <StackPanel Grid.Column="2" Grid.Row="0" Spacing="6">
                                            <TextBlock Text="الحرارة (°C)" FontSize="13" Foreground="#64748B"/>
                                            <TextBox Text="{Binding TemperatureInput}" MaxLength="5" Watermark="مثال: 37"/>
                                        </StackPanel>

                                        <!-- Heart Rate -->
                                        <StackPanel Grid.Column="0" Grid.Row="2" Spacing="6">
                                            <TextBlock Text="نبضات القلب (BPM)" FontSize="13" Foreground="#64748B"/>
                                            <TextBox Text="{Binding HeartRateInput}" MaxLength="3" Watermark="مثال: 72"/>
                                        </StackPanel>

                                        <!-- Weight -->
                                        <StackPanel Grid.Column="2" Grid.Row="2" Spacing="6">
                                            <TextBlock Text="الوزن (KG)" FontSize="13" Foreground="#64748B"/>
                                            <TextBox Text="{Binding WeightInput}" MaxLength="6" Watermark="مثال: 70.5"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Task 2: Common Medications Dropdown -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="الأدوية الشائعة" FontWeight="Medium" Foreground="#374151"/>
                                <ComboBox ItemsSource="{Binding CommonMedications}"
                                          SelectedItem="{Binding SelectedMedication}"
                                          PlaceholderText="اضغط لإضافة دواء..."
                                          HorizontalAlignment="Stretch"
                                          CornerRadius="8"/>
                            </StackPanel>

                            <!-- Prescriptions Text Area -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="الأدوية الموصوفة (حد أقصى 1000 حرف)" FontWeight="Medium" Foreground="#374151"/>
                                <TextBox Text="{Binding Prescriptions}"
                                         MaxLength="1000"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Height="80"
                                         Watermark="الأدوية والجرعات (حتى 1000 حرف)..."/>
                            </StackPanel>

                            <!-- Notes -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="ملاحظات (حد أقصى 1000 حرف)" FontWeight="Medium" Foreground="#374151"/>
                                <TextBox Text="{Binding Notes}"
                                         MaxLength="1000"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Height="60"
                                         Watermark="ملاحظات إضافية (حتى 1000 حرف)..."/>
                            </StackPanel>

                            <!-- Lab request -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="طلب فحوصات أو تحاليل مخبرية" FontWeight="Medium" Foreground="#374151"/>
                                <TextBlock Text="يمكنك كتابة الفحوصات المطلوبة (مثال: فحص CBC، كيمياء الدم، أشعة سينية للصدر)" 
                                           FontSize="12" Foreground="#64748B" TextWrapping="Wrap"/>
                                <TextBox Text="{Binding LabTestName}"
                                         MaxLength="300"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Height="56"
                                         Watermark="اكتب الفحوصات المطلوبة (حتى 300 حرف)..."/>
                            </StackPanel>

                            <!-- Task 1: Visit History Panel -->
                            <Expander Header="سجل الزيارات السابقة" 
                                      IsExpanded="{Binding IsHistoryExpanded}"
                                      CornerRadius="12"
                                      Background="#FEF3C7">
                                <Border Background="White" CornerRadius="8" Padding="12" Margin="0,8,0,0">
                                    <ScrollViewer MaxHeight="300">
                                        <ItemsControl ItemsSource="{Binding PatientHistory}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#F8FAFC" 
                                                            CornerRadius="8" 
                                                            Padding="12"
                                                            Margin="0,0,0,8">
                                                        <StackPanel Spacing="8">
                                                            <TextBlock Text="{Binding VisitDate, StringFormat='📅 {0:yyyy/MM/dd HH:mm}'}"
                                                                       FontWeight="Bold" 
                                                                       Foreground="#3B82F6"
                                                                       FontSize="14"/>
                                                            <TextBlock Text="{Binding Diagnosis, StringFormat='🩺 {0}'}" 
                                                                       TextWrapping="Wrap"
                                                                       Foreground="#1E293B"
                                                                       FontSize="13"/>
                                                            <TextBlock Text="{Binding Prescriptions, StringFormat='💊 {0}'}" 
                                                                       Foreground="#64748B" 
                                                                       FontSize="12"
                                                                       TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding Notes, StringFormat='📝 {0}'}" 
                                                                       Foreground="#94A3B8" 
                                                                       FontSize="12"
                                                                       TextWrapping="Wrap"
                                                                       IsVisible="{Binding Notes, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Complete Button (disabled until minimum info entered) -->
                    <Button Grid.Row="4" 
                            Classes="success"
                            Command="{Binding CompleteVisitCommand}"
                            IsEnabled="{Binding CanCompleteVisit}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Margin="0,20,0,0"
                            FontSize="18"
                            Padding="20,14"
                            ToolTip.Tip="سيتم تفعيل الزر بعد إدخال التشخيص أو الملاحظات أو الأدوية">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="انهاء الزيارة وحفظ"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- Modal dialog overlay (box message) -->
        <Border IsVisible="{Binding IsDialogVisible}"
                Background="#80000000"
                Grid.ColumnSpan="2">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="520">
                <Border Background="White" CornerRadius="14" Padding="18" BoxShadow="0 8 24 0 #33000000">
                    <StackPanel Spacing="14">
                        <TextBlock Text="{Binding DialogTitle}" FontSize="18" FontWeight="Bold" Foreground="#111827"/>
                        <TextBlock Text="{Binding DialogMessage}" TextWrapping="Wrap" Foreground="#374151" FontSize="14"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                            <Button Content="{Binding DialogSecondaryText}"
                                    IsVisible="{Binding IsDialogConfirm}"
                                    Command="{Binding DialogSecondaryCommand}"
                                    Background="#F1F5F9" Foreground="#0F172A"
                                    CornerRadius="8" Padding="14,10"/>

                            <!-- Primary button: normal (blue) -->
                            <Button Content="{Binding DialogPrimaryText}"
                                    IsVisible="{Binding IsDialogError, Converter={x:Static BoolConverters.Not}}"
                                    Command="{Binding DialogPrimaryCommand}"
                                    Background="#2563EB"
                                    Foreground="White"
                                    CornerRadius="8" Padding="14,10"/>

                            <!-- Primary button: error (red) -->
                            <Button Content="{Binding DialogPrimaryText}"
                                    IsVisible="{Binding IsDialogError}"
                                    Command="{Binding DialogPrimaryCommand}"
                                    Background="#DC2626"
                                    Foreground="White"
                                    CornerRadius="8" Padding="14,10"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
