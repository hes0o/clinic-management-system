<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HealthCenter.Desktop.Features.Lab.ViewModels"
             x:Class="HealthCenter.Desktop.Features.Lab.Views.LabPanelView"
             x:DataType="vm:LabPanelViewModel"
             FlowDirection="RightToLeft">

    <Grid RowDefinitions="Auto,*" Background="#F8FAFC">

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="20,14" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="لوحة المختبر" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
                    <TextBlock Text="طلبات الفحوصات المخبرية وإدخال النتائج" FontSize="13" Foreground="#64748B"/>
                </StackPanel>
                <Button Grid.Column="1" Content="تحديث" Command="{Binding RefreshTestsCommand}"
                        Padding="14,8" CornerRadius="6"
                        Background="#2563EB" Foreground="White"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*,360" Margin="16">

            <!-- Left: Pending Tests -->
            <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="16" Margin="0,0,12,0"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="الفحوصات المطلوبة" FontWeight="SemiBold" FontSize="15"
                               Foreground="#1E293B" Margin="0,0,0,12"/>
                    <ListBox Grid.Row="1" ItemsSource="{Binding RequestedTests}"
                             SelectedItem="{Binding SelectedTest}"
                             Background="Transparent"
                             IsVisible="{Binding !HasNoTests}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="14,10" CornerRadius="6" Background="#F8FAFC"
                                        Margin="0,0,0,6" BorderBrush="#E2E8F0" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding TestName}" FontWeight="SemiBold" Foreground="#1E293B"/>
                                        <TextBlock Text="{Binding Patient.FullName}" FontSize="13" Foreground="#64748B"/>
                                        <TextBlock Text="{Binding RequestedBy.FullName, StringFormat='طلب من: {0}'}"
                                                   FontSize="12" Foreground="#94A3B8"/>
                                        <TextBlock Text="{Binding RequestedAt, StringFormat='التاريخ: {0:yyyy/MM/dd}'}"
                                                   FontSize="12" Foreground="#94A3B8"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Grid.Row="1" IsVisible="{Binding HasNoTests}"
                                VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                        <TextBlock Text="📋" FontSize="40" HorizontalAlignment="Center"/>
                        <TextBlock Text="لا توجد فحوصات مطلوبة حالياً" FontSize="15"
                                   Foreground="#94A3B8" HorizontalAlignment="Center"/>
                        <TextBlock Text="ستظهر الفحوصات هنا عندما يطلبها الأطباء" FontSize="12"
                                   Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Right: Result Entry -->
            <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="24"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">
                    <TextBlock Grid.Row="0" Text="إدخال نتيجة الفحص" FontSize="17" FontWeight="SemiBold"
                               Foreground="#1E293B" Margin="0,0,0,4"/>
                    <TextBlock Grid.Row="1"
                               Text="{Binding SelectedTest.TestName, FallbackValue='لم يتم تحديد فحص'}"
                               FontSize="14" FontWeight="Medium" Foreground="#1E293B" Margin="0,0,0,4"/>
                    <TextBlock Grid.Row="2"
                               Text="{Binding SelectedTest.Patient.FullName, FallbackValue=''}"
                               FontSize="13" Foreground="#64748B" Margin="0,0,0,16"/>

                    <StackPanel Grid.Row="3" Spacing="8">
                        <TextBlock Text="ملاحظات النتيجة" FontWeight="Medium" Foreground="#374151"/>
                        <TextBox Text="{Binding ResultNotes}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 Height="140"
                                 Watermark="أدخل نتائج الفحص هنا..."/>

                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#16A34A" FontWeight="Medium"
                                   IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>

                    <Button Grid.Row="4" Content="تسجيل النتيجة - مكتمل"
                            Command="{Binding MarkCompletedCommand}"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Padding="0,12" FontSize="15" FontWeight="SemiBold"
                            Background="#7C3AED" Foreground="White" CornerRadius="8"
                            Margin="0,12,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
