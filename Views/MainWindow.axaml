<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:reception="clr-namespace:HealthCenter.Desktop.Features.Reception.Views"
        xmlns:queue="clr-namespace:HealthCenter.Desktop.Features.Queue.Views"
        xmlns:doctor="clr-namespace:HealthCenter.Desktop.Features.Doctor.Views"
        x:Class="HealthCenter.Desktop.Views.MainWindow"
        Width="1400" Height="800"
        Title="نظام إدارة المركز الصحي">

	<TabControl TabStripPlacement="Top" Padding="0" Margin="0">
		
		<TabItem Header="📝 الاستقبال وتسجيل المرضى">
			<reception:ReceptionView/>
		</TabItem>
		

		
		<TabItem Header="👨‍⚕️ لوحة الطبيب">
			<doctor:DoctorView/>
		</TabItem>
		
	</TabControl>
	
	<Window.Styles>
		<Style Selector="TabItem">
			<Setter Property="FontSize" Value="16"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Padding" Value="20,12"/>
			<Setter Property="Margin" Value="0,0,8,0"/>
		</Style>
		
		<Style Selector="TabItem:selected">
			<Setter Property="Foreground" Value="#2563EB"/>
		</Style>
	</Window.Styles>

</Window>
