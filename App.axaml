<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="HealthCenter.Desktop.App"
             xmlns:local="using:HealthCenter.Desktop"
             xmlns:converters="using:HealthCenter.Desktop.Infrastructure.Converters"
             RequestedThemeVariant="Light">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
		<StyleInclude Source="/Styles/GlobalStyles.axaml"/>
		<StyleInclude Source="/Styles/Animations.axaml"/>
		
		<!-- Global font for Arabic support -->
		<Style Selector=":is(Control)">
			<Setter Property="TextElement.FontFamily" Value="Segoe UI, Tahoma, Arial, sans-serif"/>
		</Style>
	</Application.Styles>
	<Application.Resources>
		<FontFamily x:Key="ArabicFont">
			avares://HealthCenter.Desktop/Assets/Fonts/Cairo-VariableFont_slnt,wght.ttf#Cairo
		</FontFamily>

		<!-- Override FluentTheme's internal brush resources for TextBox.
		     These are used INSIDE the control template via DynamicResource,
		     which is why outer style selectors alone cannot fix the invisible text problem. -->
		<SolidColorBrush x:Key="TextControlForeground" Color="#111827"/>
		<SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#111827"/>
		<SolidColorBrush x:Key="TextControlForegroundFocused" Color="#111827"/>
		<SolidColorBrush x:Key="TextControlForegroundDisabled" Color="#9CA3AF"/>
		<SolidColorBrush x:Key="TextControlBackground" Color="#FFFFFF"/>
		<SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#F9FAFB"/>
		<SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#FFFFFF"/>
		<SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#9CA3AF"/>
		<SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#9CA3AF"/>
		<SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#9CA3AF"/>

		<!-- ─── Value Converters (available to all views) ─────────────── -->
		<converters:TicketStatusConverter x:Key="TicketStatusConverter"/>
	</Application.Resources>
</Application>